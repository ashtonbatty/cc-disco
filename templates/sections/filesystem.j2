  # ===========================================================================
  # Filesystem Exploration
  # ===========================================================================
  directories:
    opt:
{% if _deep_filesystem %}
{% for entry in hv.disco_opt_listing.files | default([]) | sort(attribute='path') %}
      - "{{ entry.path | trim }}"
{% else %}
      []
{% endfor %}
{% else %}
      []  # skipped (collect_deep_filesystem=false)
{% endif %}
    data:
{% if _deep_filesystem %}
{% for entry in hv.disco_data_listing.files | default([]) | sort(attribute='path') %}
      - "{{ entry.path | trim }}"
{% else %}
      []
{% endfor %}
{% else %}
      []  # skipped (collect_deep_filesystem=false)
{% endif %}
{% if _deep_filesystem and _command_heavy %}
{% set _thirdparty = hv.disco_third_party_paths.stdout | default('') | trim %}
{% if _thirdparty | length > 0 %}
    third_party_paths: |
{{ _thirdparty | indent(6, true) }}
{% else %}
    third_party_paths: null
{% endif %}
{% else %}
    third_party_paths: null  # skipped (deep_filesystem or command_heavy_probes disabled)
{% endif %}
