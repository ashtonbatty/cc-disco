  # ===========================================================================
  # Security
  # ===========================================================================
  security:
{% set _sudoers = (hv.disco_sudoers_main.content | default('') | b64decode) | trim %}
{% if _sudoers | length > 0 %}
    sudoers_main: |
{{ _sudoers | indent(6, true) }}
{% else %}
    sudoers_main: null
{% endif %}
    sudoers_drop_ins:
{% if _deep_security %}
{% for item in hv.disco_sudoers_d_contents.results | default([]) %}
{% if item.content is defined %}
      - file: "{{ item.item.path }}"
        content: |
{{ (item.content | b64decode) | indent(10, true) }}
{% endif %}
{% else %}
      []
{% endfor %}
{% else %}
      []  # skipped (collect_deep_security=false)
{% endif %}
{% set _sshd = (hv.disco_sshd_config.content | default('') | b64decode) | trim %}
{% if _sshd | length > 0 %}
    sshd_config: |
{{ _sshd | indent(6, true) }}
{% else %}
    sshd_config: null
{% endif %}
    sshd_config_drop_ins:
{% if _deep_security %}
{% for item in hv.disco_sshd_d_contents.results | default([]) %}
{% if item.content is defined %}
      - file: "{{ item.item.path }}"
        content: |
{{ (item.content | b64decode) | indent(10, true) }}
{% endif %}
{% else %}
      []
{% endfor %}
{% else %}
      []  # skipped (collect_deep_security=false)
{% endif %}
    pam:
{% if _deep_security %}
{% for item in hv.disco_pam_contents.results | default([]) %}
{% if item.content is defined %}
      - file: "{{ item.item }}"
        content: |
{{ (item.content | b64decode) | indent(10, true) }}
{% endif %}
{% else %}
      []
{% endfor %}
{% else %}
      []  # skipped (collect_deep_security=false)
{% endif %}
{% set _crypto = (hv.disco_crypto_policy | default({})).stdout | default('') | trim %}
    crypto_policy: {{ _crypto | to_json if _crypto | length > 0 else 'null' }}
