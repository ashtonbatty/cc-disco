---
{{ ansible_managed | comment }}
#
# RHEL Server Discovery Report
#
# WARNING: This report contains security-sensitive data (sudoers, sshd, PAM, SSSD).
# Handle with the same care as a credentials file. Do not share unredacted.
#
# Null convention: fields with value `null` indicate data was not collected,
# not applicable, or the source was unavailable. Parsers should treat null
# as "no data" — never as a valid result.
#
{% set _hosts = report_hosts | default(groups['all'] | difference(['localhost'])) %}
{% if _hosts | length == 0 %}
# No hosts were scanned. Check inventory and --limit arguments.
{% else %}
# Generated: {{ hostvars[_hosts[0]].ansible_date_time.iso8601 }}
{% endif %}
# Total hosts scanned: {{ _hosts | length }}

{% for host in (report_hosts | default(groups['all'] | difference(['localhost']))) | sort %}
{% set hv = hostvars[host] %}
{% if hv.ansible_hostname is defined %}
{{ host }}:

{% include 'sections/system.j2' %}

{% include 'sections/platform.j2' %}

{% include 'sections/network.j2' %}

{% include 'sections/firewall.j2' %}

{% include 'sections/storage.j2' %}

{% include 'sections/selinux.j2' %}

{% include 'sections/security.j2' %}

{% include 'sections/identity.j2' %}

{% include 'sections/kernel.j2' %}

{% include 'sections/services.j2' %}

{% include 'sections/packages.j2' %}

{% include 'sections/satellite.j2' %}

{% include 'sections/backup.j2' %}

{% include 'sections/filesystem.j2' %}

{% include 'sections/readiness.j2' %}

{% endif %}
{% endfor %}
